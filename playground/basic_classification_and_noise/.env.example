# LLM config for the few-shot classifier.
# Copy this file to .env (in this same folder, next to notebook.ipynb) and fill in your key.
# Set LIVE=true to actually call the LLM; otherwise the lab uses a deterministic mock.

LIVE=false

# --- OpenRouter (default; OpenAI-compatible) ---
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1   # only change to use a different gateway

# --- Alternatives (used only if OPENROUTER_API_KEY is empty) ---
# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
